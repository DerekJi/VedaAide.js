// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Stores document chunks with their vector embeddings
model VectorChunk {
  id          String   @id @default(cuid())
  content     String
  contentHash String?  // SHA-256 of chunk content for chunk-level deduplication
  embedding   String   // JSON-encoded float array
  metadata    String   @default("{}") // JSON-encoded metadata object
  fileId      String?
  syncedFile  SyncedFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fileId])
  @@index([contentHash])
}

/// Stores prompt templates for different use cases with version support
model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  content     String   // Prompt content (was 'template' in v1, renamed for clarity)
  version     Int      @default(1)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, version])
  @@index([name, isActive])
}

/// Tracks files that have been synced/ingested
model SyncedFile {
  id          String   @id @default(cuid())
  name        String
  source      String   // file path or blob URL
  contentHash String   // SHA-256 of file content for deduplication
  chunkCount  Int      @default(0)
  status      String   @default("pending") // pending | processing | completed | failed
  errorMessage String?
  chunks      VectorChunk[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source])
  @@index([contentHash])
  @@index([status])
}
