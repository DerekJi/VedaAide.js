# Production environment configuration
# Deploy via: az containerapp update --set-env-vars (or GitHub Actions secrets)
# All secrets must be stored in Azure Key Vault — never hardcoded or committed.

NODE_ENV=production
DATABASE_URL=file:./prod.db
LOG_LEVEL=warn

# ── LLM (Azure OpenAI in production) ──────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://vedaaide.openai.azure.com/
AZURE_OPENAI_API_KEY=<production-key-from-keyvault>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
DEPLOYMENT_MODE=true

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_BLOB_ACCOUNT_NAME=vedaaideprod
AZURE_BLOB_ACCOUNT_KEY=<key-from-keyvault>
AZURE_BLOB_CONTAINER_NAME=documents

# ── Monitoring ─────────────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=<production-connection-string>

# ── Data sync ─────────────────────────────────────────────────────────────────
DATA_SYNC_PATH=/app/data
