# Staging environment configuration
# Deploy via: az containerapp update --set-env-vars (or GitHub Actions secrets)
# All secrets should be stored in Azure Key Vault or GitHub Secrets — never hardcoded.

NODE_ENV=production
DATABASE_URL=file:./staging.db
LOG_LEVEL=info

# ── LLM (Azure OpenAI in staging) ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://vedaaide-staging.openai.azure.com/
AZURE_OPENAI_API_KEY=<staging-key-from-keyvault>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
DEPLOYMENT_MODE=true

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_BLOB_ACCOUNT_NAME=vedaaidestaging
AZURE_BLOB_ACCOUNT_KEY=<key-from-keyvault>
AZURE_BLOB_CONTAINER_NAME=documents-staging

# ── Monitoring ─────────────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=<staging-connection-string>

# ── Data sync ─────────────────────────────────────────────────────────────────
DATA_SYNC_PATH=/app/data/staging
