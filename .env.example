# Environment variable template
# Copy to .env and fill in your values
# Do NOT commit .env to source control

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=file:./dev.db
LOG_LEVEL=info

# ── Ollama (local LLM — required unless using Azure OpenAI) ──────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen:7b-chat

# ── Azure OpenAI (optional — replaces Ollama in production) ──────────────────
# AZURE_OPENAI_ENDPOINT=https://<name>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<key>
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Set DEPLOYMENT_MODE=true to use Managed Identity instead of API key
# DEPLOYMENT_MODE=false

# ── Azure Cosmos DB (optional — replaces SQLite vector store) ─────────────────
# AZURE_COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# AZURE_COSMOS_KEY=<key>
# AZURE_COSMOS_DATABASE=vedaaide
# AZURE_COSMOS_CONTAINER=vectors

# ── Azure Blob Storage (optional — document source connector, not yet impl.) ──
# AZURE_BLOB_ACCOUNT_NAME=<account>
# AZURE_BLOB_ACCOUNT_KEY=<key>
# AZURE_BLOB_CONTAINER_NAME=documents

