# ─────────────────────────────────────────────────────────────────────────────
# VedaAide.js Environment Variables Template
# Copy this to .env.local and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# Set to "true" when deploying to Azure (uses Managed Identity, skips API keys)
DEPLOYMENT_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
# Mode 1 (local dev): SQLite file
DATABASE_URL=file:./dev.db

# ── Ollama (local development only) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# ── Azure OpenAI (optional – local Azure testing | auto via Managed Identity in deployment) ──
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<your-api-key>
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure Cosmos DB (optional – same as above) ────────────────────────────────
# AZURE_COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
# AZURE_COSMOS_KEY=<your-primary-key>
# AZURE_COSMOS_DATABASE=vedaaide
# AZURE_COSMOS_CONTAINER=vectors

# ── Azure Blob Storage (optional) ─────────────────────────────────────────────
# AZURE_BLOB_ACCOUNT_NAME=<your-storage-account>
# AZURE_BLOB_ACCOUNT_KEY=<your-access-key>
# AZURE_BLOB_CONTAINER_NAME=documents
